# Copy to backend/.env for local backend commands.
# Keep OPENAI_COMPATIBLE_API_KEY empty in tracked files.

APP_NAME=AI Agent Lab Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./ai_agent_lab.db
BACKEND_CORS_ORIGINS=http://localhost:5173
OPENAI_COMPATIBLE_BASE_URL=https://api.example.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=example-model
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=30
